<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    Đây là màn hình thống kê tổng quan của thủ thư.
    Nó gồm 4 vùng chính:
    1. Header với tiêu đề + bộ lọc tháng + nút làm mới.
    2. Hàng KPI thống kê nhanh.
    3. Hai biểu đồ.
    4. Hai bảng top.
-->
<StackPane fx:controller="com.example.librarian.controller.StatisticalManagementController"
           maxWidth="1.7976931348623157E308"
           maxHeight="1.7976931348623157E308"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">

    <VBox spacing="20.0">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Thống kê Tổng quan" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />

            <!-- Combobox tháng: hiện mới là UI chọn tháng, controller chưa lọc dữ liệu theo giá trị này -->
            <ComboBox fx:id="monthFilter"
                      prefWidth="150.0"
                      promptText="Tháng này"
                      style="-fx-background-radius: 8;" />

            <!-- Gọi refreshData() trong controller -->
            <Button text="Làm mới"
                    onAction="#refreshData"
                    styleClass="btn-primary"/>
        </HBox>

        <!-- Hàng KPI -->
        <HBox spacing="20.0">
            <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                <Label text="TỔNG SỐ SÁCH" textFill="#888888">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label fx:id="totalBooksLabel" text="0" textFill="#233771">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
            </VBox>

            <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                <Label text="TỔNG ĐỘC GIẢ" textFill="#888888">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label fx:id="totalReadersLabel" text="0" textFill="#00bfff">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
            </VBox>

            <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                <Label text="ĐANG ĐƯỢC MƯỢN" textFill="#888888">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label fx:id="borrowingLabel" text="0" textFill="#f0ad4e">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
            </VBox>

            <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                <Label text="QUÁ HẠN TRẢ" textFill="#888888">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
                <Label fx:id="overdueLabel" text="0" textFill="#d9534f">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
            </VBox>
        </HBox>

        <!-- Khu vực biểu đồ -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">

            <VBox spacing="10.0"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                <Label text="Số lượng sách theo thể loại" textFill="#233771">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>

                <!-- BarChart: dữ liệu được controller nạp bằng loadCategoryChart() -->
                <BarChart fx:id="categoryChart" VBox.vgrow="ALWAYS" animated="false" legendVisible="false">
                    <xAxis>
                        <NumberAxis label=""
                                    tickUnit="1"
                                    minorTickCount="0"
                                    forceZeroInRange="true"/>
                    </xAxis>

                    <yAxis>
                        <CategoryAxis label=""/>
                    </yAxis>
                </BarChart>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                <Label text="Lượt mượn sách các tháng trong năm" textFill="#233771">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>

                <!-- LineChart: dữ liệu được controller nạp bằng loadBorrowTrendChart() -->
                <LineChart fx:id="borrowTrendChart" VBox.vgrow="ALWAYS" animated="false" legendVisible="false">
                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT"
                                    tickUnit="1"
                                    minorTickCount="0"
                                    forceZeroInRange="true"/>
                    </yAxis>
                </LineChart>
            </VBox>
        </HBox>

        <!-- Khu vực 2 bảng top -->
        <HBox spacing="20.0" prefHeight="250.0">

            <VBox spacing="10.0"
                  style="-fx-background-color: white; -fx-background-radius: 15;
             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);
             -fx-padding: 20;"
                  HBox.hgrow="ALWAYS">

                <Label text="Top 5 Sách mượn nhiều nhất" textFill="#233771">
                    <font>
                        <Font name="System Bold" size="16.0"/>
                    </font>
                </Label>

                <!-- Bảng top sách -->
                <TableView fx:id="topBooksTable"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">

                    <columns>
                        <TableColumn fx:id="colTitle"
                                     prefWidth="200.0"
                                     text="Tên sách"/>

                        <TableColumn fx:id="colTotal"
                                     prefWidth="100.0"
                                     text="Lượt mượn"/>
                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                <Label text="Độc giả hoạt động tích cực" textFill="#233771">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>

                <!-- Bảng top độc giả -->
                <TableView fx:id="topReadersTable"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;"
                           VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="colReaderName"
                                     prefWidth="200.0"
                                     text="Họ tên"/>

                        <TableColumn fx:id="colReaderTotal"
                                     prefWidth="100.0"
                                     text="Số phiếu"/>
                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </HBox>
    </VBox>
</StackPane>
