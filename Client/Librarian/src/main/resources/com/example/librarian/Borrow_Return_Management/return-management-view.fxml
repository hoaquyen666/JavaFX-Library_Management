<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>

<StackPane stylesheets="@borrow.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.librarian.controller.ReturnManagementController">

   <VBox spacing="20.0">
      <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <Label text="Quản lý trả sách" textFill="WHITE">
            <font><Font name="System Bold" size="24.0" /></font>
         </Label>
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#handleReturnAction" style="-fx-background-color: #31b865; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="✓ Xác nhận trả sách">
            <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
            <font><Font name="System Bold" size="13.0" /></font>
         </Button>
      </HBox>

      <VBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
         <HBox alignment="CENTER_LEFT" spacing="15.0">
            <TextField fx:id="txtSearch" promptText="Tìm mã phiếu..." style="-fx-background-radius: 8;" HBox.hgrow="ALWAYS" />
         </HBox>

         <TableView fx:id="returnTable" VBox.vgrow="ALWAYS" styleClass="borrow-table">
            <columns>
               <TableColumn fx:id="colBorrowId" prefWidth="80.0" text="Mã Phiếu" />
               <TableColumn fx:id="colReaderId" prefWidth="80.0" text="Mã ĐG" />
               <TableColumn fx:id="colReaderName" prefWidth="150.0" text="Tên Độc Giả" />
               <TableColumn fx:id="colCopyId" prefWidth="120.0" text="Mã Cuốn (BC)" />
               <TableColumn fx:id="colBookName" prefWidth="200.0" text="Tên Sách" />
               <TableColumn fx:id="colDeposit" prefWidth="100.0" text="Tiền Cọc" />
               <TableColumn fx:id="colFine" prefWidth="100.0" text="Tiền Phạt" />
               <TableColumn fx:id="colStatus" prefWidth="100.0" text="Trạng Thái" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
         </TableView>

         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Button fx:id="btnPrevPage" text="&lt;" />
            <Label fx:id="lblPageInfo" text="Trang 1 / 1" />
            <Button fx:id="btnNextPage" text="&gt;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Tổng cộng:" />
            <Label fx:id="lblTotalReturns" style="-fx-font-weight: bold;" />
         </HBox>
      </VBox>
   </VBox>

