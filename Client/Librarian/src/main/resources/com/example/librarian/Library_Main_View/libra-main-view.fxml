<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #111827;" stylesheets="@libra-main.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.librarian.controller.MainViewController">

    <left>
        <VBox fx:id="sidebar" prefWidth="70.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <StackPane prefHeight="80.0">
                    <ImageView fx:id="logoImage" fitHeight="140.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../../../../images/img_1.png" />
                        </image>
                  <StackPane.margin>
                     <Insets bottom="25.0" top="35.0" />
                  </StackPane.margin>
                    </ImageView>
                </StackPane>

                <Button alignment="CENTER_LEFT" onAction="#handleTrangChu" styleClass="menu-btn" text="Trang chủ">
                    <graphic>
                        <FontIcon iconLiteral="mdi2h-home" iconSize="20" />
                    </graphic>
                </Button>

                <Button alignment="CENTER_LEFT" onAction="#handleQuanLySach" styleClass="menu-btn" text="Quản lý sách">
                    <graphic>
                        <FontIcon iconLiteral="mdi2b-book" iconSize="20" />
                    </graphic>
                </Button>

                <Button alignment="CENTER_LEFT" onAction="#handleQuanLyDocGia" styleClass="menu-btn" text="Quản lý Độc giả">
                    <graphic>
                        <FontIcon iconLiteral="mdi2a-account-group" iconSize="20" />
                    </graphic>
                </Button>

                <Button alignment="CENTER_LEFT" onAction="#handleQuanLyMuonTra" styleClass="menu-btn" text="Quản lý mượn trả">
                    <graphic>
                        <FontIcon iconLiteral="mdi2r-refresh" iconSize="20" />
                    </graphic>
                </Button>

                <VBox fx:id="muonTraSubMenu" managed="false" style="-fx-padding: 0 0 0 30;" visible="false">
                    <Button alignment="CENTER_LEFT" onAction="#handleQuanLyMuon" styleClass="sub-menu-btn" text="Mượn sách">
                        <graphic>
                            <FontIcon iconLiteral="mdi2b-book-arrow-right" iconSize="18" />
                        </graphic>
                    </Button>
                    <Button alignment="CENTER_LEFT" onAction="#handleQuanLyTra" styleClass="sub-menu-btn" text="Trả sách">
                        <graphic>
                            <FontIcon iconLiteral="mdi2b-book-arrow-left" iconSize="18" />
                        </graphic>
                    </Button>
                </VBox>

                <Button alignment="CENTER_LEFT" onAction="#handleQuanLyKho" styleClass="menu-btn" text="Quản lý kho hàng">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-package-variant" iconSize="20" />
                    </graphic>
                </Button>
                <VBox fx:id="menuQuanLyKho" managed="false" style="-fx-padding: 0 0 0 30;" visible="false">
                    <Button alignment="CENTER_LEFT" onAction="#handleQuanLyNhap" styleClass="sub-menu-btn" text="Quản lý nhập">
                        <graphic>
                            <FontIcon iconLiteral="mdi2t-truck-delivery" iconSize="18" />
                        </graphic>
                    </Button>
                    <Button alignment="CENTER_LEFT" onAction="#handleNhaCungCap" styleClass="sub-menu-btn" text="Nhà cung cấp">
                        <graphic>
                            <FontIcon iconLiteral="mdi2d-domain" iconSize="18" />
                        </graphic>
                    </Button>
                </VBox>

                <Button alignment="CENTER_LEFT" onAction="#handleQuanLyThongKe" styleClass="menu-btn" text="Quản lý thống kê">
                    <graphic>
                        <FontIcon iconLiteral="mdi2c-chart-bar" iconSize="20" />
                    </graphic>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" right="30.0" top="50.0" />
            </padding>
            <children>
                <StackPane fx:id="mainContentArea" styleClass="main-content-card">
                    <!--                    <children>-->
                    <!--                        <Label text="HỆ THỐNG QUẢN LÝ THƯ VIỆN" textFill="#a1a1a1">-->
                    <!--                            <font>-->
                    <!--                                <Font name="System Bold" size="20.0" />-->
                    <!--                            </font>-->
                    <!--                        </Label>-->
                    <!--                    </children>-->
                </StackPane>
            </children>
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
        </StackPane>
    </center>
</BorderPane>
