<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: transparent;"
           maxWidth="1.7976931348623157E308"
           maxHeight="1.7976931348623157E308"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.librarian.controller.SupplierManagementController">

    <VBox spacing="20.0">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Quản lý nhà cung cấp" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS" />

            <Button style="-fx-background-color: #233771; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Thêm" onAction="#handleAddSupplier">
                <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                <font><Font name="System Bold" size="13.0" /></font>
            </Button>
            <Button style="-fx-background-color: #f0ad4e; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Sửa" onAction="#handleEditSupplier">
                <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                <font><Font name="System Bold" size="13.0" /></font>
            </Button>
            <Button style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Xóa"  onAction="#handleDeleteSupplier">
                <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                <font><Font name="System Bold" size="13.0" /></font>
            </Button>
        </HBox>

        <VBox spacing="20.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white;
                   -fx-background-radius: 20;
                   -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);
                   -fx-padding: 20;">

            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <ComboBox fx:id="statusFilter" prefWidth="180.0" promptText="Tất cả trạng thái" style="-fx-background-radius: 8;" />

                <TextField fx:id="searchField" promptText="Tìm theo tên / SĐT / Email..." style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-padding: 8;" HBox.hgrow="ALWAYS" />

                <Button style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Tìm kiếm" onAction="#onSearchAction">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                </Button>
            </HBox>

            <VBox VBox.vgrow="ALWAYS">
                <TableView fx:id="supplierTable" style="-fx-background-color: transparent; -fx-border-color: #e0e0e0; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSelect" prefWidth="30.0" text="STT" />
                        <TableColumn fx:id="colSupplierCode" prefWidth="80.0" text="Mã NCC" />
                        <TableColumn fx:id="colSupplierName" prefWidth="200.0" text="Tên NCC" />
                        <TableColumn fx:id="colPhone" prefWidth="120.0" text="Điện thoại" />
                        <TableColumn fx:id="colEmail" prefWidth="160.0" text="Email" />
                        <TableColumn fx:id="colAddress" prefWidth="180.0" text="Địa chỉ" />
                        <TableColumn fx:id="colStatus" prefWidth="90.0" text="Trạng thái" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Tổng cộng:" textFill="#666666" />
                <Label fx:id="totalCountLabel" text="0 bản ghi" textFill="#233771">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Button style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-cursor: hand;" text="&lt;" textFill="#666666" />
                <Label text="1" textFill="#233771">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Button style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-cursor: hand;" text="&gt;" textFill="#666666" />

                <ComboBox fx:id="pageSizeCombo" prefWidth="110.0" promptText="20 / trang" style="-fx-background-radius: 8;" />
            </HBox>

        </VBox>
    </VBox>
</StackPane>