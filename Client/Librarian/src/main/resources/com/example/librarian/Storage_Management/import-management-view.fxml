<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: transparent;"
           maxWidth="1.7976931348623157E308"
           maxHeight="1.7976931348623157E308"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1">

    <VBox spacing="20.0">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Quản lý nhập sách" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS" />

            <Button style="-fx-background-color: #233771; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Thêm">
                <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                <font><Font name="System Bold" size="13.0" /></font>
            </Button>
            <Button style="-fx-background-color: #f0ad4e; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Sửa">
                <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                <font><Font name="System Bold" size="13.0" /></font>
            </Button>
            <Button style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Xóa">
                <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                <font><Font name="System Bold" size="13.0" /></font>
            </Button>
        </HBox>

        <VBox spacing="20.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white;
                   -fx-background-radius: 20;
                   -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);
                   -fx-padding: 20;">

            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <ComboBox fx:id="supplierFilter" prefWidth="200.0" promptText="Tất cả nhà cung cấp" style="-fx-background-radius: 8;" />

                <TextField fx:id="searchField" promptText="Tìm theo mã phiếu / nhà cung cấp..." style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-padding: 8;" HBox.hgrow="ALWAYS" />

                <Button style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Tìm kiếm">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                </Button>
            </HBox>

            <VBox VBox.vgrow="ALWAYS">
                <TableView fx:id="importTable" style="-fx-background-color: transparent; -fx-border-color: #e0e0e0; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNumber" prefWidth="30.0" text="STT" />
                        <TableColumn fx:id="colImportCode" prefWidth="100.0" text="Mã phiếu" />
                        <TableColumn fx:id="colSupplier" prefWidth="220.0" text="Nhà cung cấp" />
                        <TableColumn fx:id="colImportDate" prefWidth="120.0" text="Ngày nhập" />
                        <TableColumn fx:id="colBookName" prefWidth="150.0" text="Tên sách" />
                        <TableColumn fx:id="colQuantity" prefWidth="120.0" text="Số lượng" />
                        <TableColumn fx:id="colTotalPrice" prefWidth="150.0" text="Tổng tiền" />
                        <TableColumn fx:id="colStatus" prefWidth="90.0" text="Trạng thái" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Tổng cộng:" textFill="#666666" />
                <Label fx:id="totalCountLabel" text="0 phiếu" textFill="#233771">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Button style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-cursor: hand;" text="&lt;" textFill="#666666" />
                <Label text="1" textFill="#233771">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Button style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-cursor: hand;" text="&gt;" textFill="#666666" />
            </HBox>

        </VBox>
    </VBox>
</StackPane>