<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.DatePicker?>

<?import javafx.scene.control.ListView?>
<StackPane style="-fx-background-color: transparent;"
           stylesheets="@borrow.css"
           maxWidth="1.7976931348623157E308"
           maxHeight="1.7976931348623157E308"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.librarian.controller.BorrowManagementController">

   <VBox spacing="20.0">
      <padding>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </padding>

      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <Label text="Quản lý mượn sách" textFill="WHITE">
            <font>
               <Font name="System Bold" size="24.0" />
            </font>
         </Label>

         <Region HBox.hgrow="ALWAYS" />

         <Button onAction="#handleAddBorrow" styleClass="btn-add" text="+ Tạo phiếu mượn">
            <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
            <font><Font name="System Bold" size="13.0" /></font>
         </Button>
         <Button onAction="#handleEditBorrow" styleClass="btn-edit" text="Sửa phiếu">
            <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
            <font><Font name="System Bold" size="13.0" /></font>
         </Button>
      </HBox>

      <VBox spacing="20.0"
            stylesheets="@borrow.css"
            VBox.vgrow="ALWAYS"
            style="-fx-background-color: white;
                   -fx-background-radius: 20;
                   -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);
                   -fx-padding: 15;">

         <HBox alignment="CENTER_LEFT" spacing="15.0">
            <ComboBox fx:id="cbStatusFilter" prefWidth="150.0" promptText="Trạng thái" style="-fx-background-radius: 8;" styleClass="combo-box" />
            <ComboBox fx:id="cbDateFilter" prefWidth="150.0" promptText="Sắp đến hạn" style="-fx-background-radius: 8;" />

            <TextField fx:id="txtSearch" promptText="Tìm mã phiếu, mã độc giả, tên sách..." style="-fx-background-radius: 5; -fx-border-color: #bfe5ff; -fx-border-radius: 5; -fx-padding: 8;" HBox.hgrow="ALWAYS" />
         </HBox>

         <VBox stylesheets="@borrow.css"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: white;
                   -fx-background-radius: 20;
                   -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);
                   -fx-padding: 15;">
            <TableView fx:id="borrowTable"
                       styleClass="borrow-table"
                       editable="true"
                       prefHeight="400.0"
                       style="-fx-background-color: transparent;
                       -fx-border-color: #e0e0e0;
                       -fx-border-radius: 8;"
                       VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colStt" prefWidth="30.0" text="STT" />
                  <TableColumn fx:id="colBorrowId" prefWidth="30.0" text="ID" />
                  <TableColumn fx:id="colBorrowCode" prefWidth="90.0" text="Mã Phiếu Mượn" />
                  <TableColumn fx:id="colReaderCode" prefWidth="130.0" text="Độc Giả" />
                  <TableColumn fx:id="colStaffCode" prefWidth="180.0" text="Nhân Viên" />
                  <TableColumn fx:id="colBorrowDate" prefWidth="90.0" text="Ngày Mượn" />
                  <TableColumn fx:id="colDueDate" prefWidth="90.0" text="Hạn Trả" />
                  <TableColumn fx:id="colQuantity" prefWidth="90.0" text="Số lượng" />
                  <TableColumn fx:id="colStatus" prefWidth="90.0" text="Trạng Thái" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </VBox>

         <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10 0 0 0;">

            <HBox alignment="CENTER" spacing="5.0">
               <Button fx:id="btnPrevPage" onAction="#handlePrevPage" text="&lt;" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 3 10;"/>
               <Label fx:id="lblPageInfo" text="Trang 1 / 1" textFill="#233771">
                  <font><Font name="System Bold" size="12.0" /></font>
               </Label>
               <Button fx:id="btnNextPage" onAction="#handleNextPage" text="&gt;" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 3 10;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <Label text="Tổng cộng:" textFill="#666666" />
            <Label fx:id="lblTotalBorrows" textFill="#233771" >
               <font><Font name="System Bold" size="13.0" /></font>
            </Label>
         </HBox>

      </VBox>
   </VBox>

   <StackPane fx:id="addPopupOverlay" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.5); -fx-background-radius: 20;">

      <VBox maxWidth="550.0" maxHeight="-Infinity" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 5);">

         <Label fx:id="lblPopupTitle" text="Tạo Phiếu Mượn Mới" textFill="#233771">
            <font><Font name="System Bold" size="22.0" /></font>
         </Label>

         <GridPane vgap="15.0" hgap="15.0">
            <columnConstraints>
               <ColumnConstraints minWidth="110.0" />
               <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Độc Giả:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="cbPopupReader" promptText="-- Chọn Độc giả --" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Nhân Viên:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="cbPopupStaff" promptText="-- Chọn Nhân viên --" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Ngày hẹn trả:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <DatePicker fx:id="dpPopupDueDate" promptText="Chọn ngày trả" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="ID Bản sao sách:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="txtPopupCopyIds" promptText="VD: 1, 1, 2" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="(Nhập các CopyID cách nhau bằng dấu phẩy)" textFill="#888888" GridPane.columnIndex="1" GridPane.rowIndex="4">
               <font><Font size="11.0" /></font>
            </Label>
         </GridPane>

         <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <Button onAction="#handleClosePopup" style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand;" text="Hủy bỏ" />
            <Button onAction="#handleSaveBorrow" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;" text="Lưu phiếu" />
         </HBox>
      </VBox>
   </StackPane>
   <StackPane fx:id="detailPopupOverlay" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.5); -fx-background-radius: 20;">
      <VBox maxWidth="550.0" maxHeight="-Infinity" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 5);">

         <Label fx:id="lblDetailTitle" text="Chi Tiết Phiếu Mượn" textFill="#233771">
            <font><Font name="System Bold" size="22.0" /></font>
         </Label>

         <GridPane vgap="10.0" hgap="15.0">
            <columnConstraints>
               <ColumnConstraints minWidth="100.0" />
               <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <Label text="Người mượn:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
            <Label fx:id="lblDetailReader" text="..." GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-text-fill: #000;"/>

            <Label text="Nhân viên:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
            <Label fx:id="lblDetailStaff" text="..." GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-text-fill: #000;"/>

            <Label text="Thời gian:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
            <Label fx:id="lblDetailTime" text="..." GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-text-fill: #000;"/>
         </GridPane>

         <Label text="Danh sách sách đã mượn:" style="-fx-font-weight: bold; -fx-padding: 10 0 0 0;" />

         <ListView fx:id="lvDetailBooks" prefHeight="150.0" style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" />

         <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
            <Button onAction="#handleCloseDetailPopup" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;" text="Đóng" />
         </HBox>
      </VBox>
   </StackPane>
</StackPane>