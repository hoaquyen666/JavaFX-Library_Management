<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent;" stylesheets="@book-management.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.librarian.controller.BookCopyManagementController">

    <VBox spacing="20.0" styleClass="main-content-card">
        <padding><Insets bottom="20.0" left="30.0" right="30.0" top="60.0" /></padding>

        <Label text="Quản lý Bản sao sách" textFill="#fff">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card">
            <TextField fx:id="searchField" prefWidth="300.0" promptText="Tìm mã vạch, tên sách..." style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-padding: 8;" />
            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#handleEditCopy" styleClass="btn-edit" text="Sửa thông tin">
                <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                <font><Font name="System Bold" size="13.0" /></font>
            </Button>
        </HBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" VBox.vgrow="ALWAYS">
            <TableView fx:id="copyTable" prefHeight="400.0" styleClass="book-table" style="-fx-background-color: transparent; -fx-border-color: #e0e0e0; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCopyId" prefWidth="60.0" text="ID bản sao" />
                    <TableColumn fx:id="colBookId" prefWidth="60.0" text="ID sách" />
                    <TableColumn fx:id="colBookTitle" prefWidth="300.0" text="Tên Sách" />
                    <TableColumn fx:id="colStatus" prefWidth="120.0" text="Trạng thái" />
                    <TableColumn fx:id="colLocation" prefWidth="120.0" text="Vị trí kệ" />
                    <TableColumn fx:id="colNote" prefWidth="150.0" text="Ghi chú" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 10 0 0 0;">
                <Label fx:id="lblTotalRecords" textFill="#233771">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handlePrevPage" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 3; -fx-cursor: hand;" text="&lt;" />
                <Label fx:id="lblCurrentPage" style="-fx-font-weight: bold; -fx-text-fill: #1a73e8;" text="1" />
                <Button onAction="#handleNextPage" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 3; -fx-cursor: hand;" text="&gt;" />
                <ComboBox fx:id="cbRowsPerPage" prefWidth="100.0" style="-fx-background-radius: 8;" />
            </HBox>
        </VBox>
    </VBox>

    <StackPane fx:id="editPopupOverlay" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.5); -fx-background-radius: 20 ;">
        <VBox maxHeight="-Infinity" maxWidth="500.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 5);">
            <Label text="Cập nhật Trạng thái &amp; Vị trí" textFill="#233771">
                <font><Font name="System Bold" size="22.0" /></font>
            </Label>

            <Label fx:id="lblPopupBookInfo" text="Sách: ..." style="-fx-font-style: italic; -fx-text-fill: #666;" />

            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="90.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Trạng thái:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="cbPopupStatus" prefWidth="300" style="-fx-padding: 4; -fx-background-radius: 5; -fx-border-color: #ddd;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Vị trí kệ:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtPopupLocation" promptText="VD: Tầng 1 - Kệ A2" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #ddd;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Ghi chú:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtPopupNote" promptText="Ghi chú tình trạng sách..." style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #ddd;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                <Button onAction="#handleClosePopup" style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand;" text="Hủy bỏ" />
                <Button onAction="#handleSaveCopy" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;" text="Lưu cập nhật" />
            </HBox>
        </VBox>
    </StackPane>
</StackPane>