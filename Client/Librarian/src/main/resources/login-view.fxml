<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #1a2f57;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.librarian.controller.LoginController">

  <!-- khung chứa thẻ (Nền trắng, bo góc, đổ bóng) -->
  <VBox alignment="CENTER" maxWidth="360" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);">
    <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- Tiêu đề -->
    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a73e8;" text="Thư Viện" />
    <Label style="-fx-font-size: 13; -fx-text-fill: #666;" text="Đăng nhập tài khoản thủ thư" />

    <!-- Khoảng cách -->
    <Region prefHeight="5" />

    <!-- Username -->
    <TextField fx:id="txtUsername" promptText="Tên đăng nhập" style="-fx-padding: 10; -fx-font-size: 13; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />

    <!-- Password -->
    <PasswordField fx:id="txtPassword" promptText="Mật khẩu" style="-fx-padding: 10; -fx-font-size: 13; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;">
         <VBox.margin>
            <Insets />
         </VBox.margin></PasswordField>

    <!-- Label báo lỗi -->
    <Label fx:id="lblError" managed="false" style="-fx-text-fill: red; -fx-font-size: 12;" text="" visible="false" />

    <!-- Nút login -->
    <Button defaultButton="true" maxWidth="Infinity" onAction="#onLoginClick" style="-fx-background-color: #1a73e8;             -fx-text-fill: white;             -fx-font-size: 14;             -fx-font-weight: bold;             -fx-padding: 10;             -fx-background-radius: 5;             -fx-cursor: hand;" text="Đăng nhập" />

    <!-- Separator ngăn cách -->
    <Separator />
  </VBox>
   <padding>
      <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
   </padding>
</VBox>
