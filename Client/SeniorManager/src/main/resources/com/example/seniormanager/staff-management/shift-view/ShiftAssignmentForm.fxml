<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8px"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.seniormanager.controller.Shift.ShiftAssignmentController">

    <Label fx:id="lblTitle" text="Phân Công Ca Làm" textFill="#233771">
        <font><Font name="System Bold" size="20.0" /></font>
    </Label>

    <VBox style="-fx-background-color: #f8fafc; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #e2e8f0; -fx-border-radius: 5;">
        <Label fx:id="lblStaffInfo" text="Nhân viên: Nguyễn Văn A">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <Label fx:id="lblDateInfo" text="Ngày: 20/10/2023" textFill="#64748b">
            <font><Font name="System Italic" size="13.0" /></font>
        </Label>
    </VBox>

    <GridPane hgap="10" vgap="15">
        <Label text="Chọn Ca Làm:" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <ComboBox fx:id="cbShift" prefWidth="250.0" promptText="-- Lựa chọn giờ làm --" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <CheckBox fx:id="chkAttendance" text="Đã điểm danh (Có mặt)" textFill="#16a34a" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <font><Font name="System Bold" size="13.0" /></font>
        </CheckBox>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <VBox.margin><Insets top="15.0" /></VBox.margin>
        <Button onAction="#handleCancel" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-cursor: hand;" text="Hủy" />
        <Button onAction="#handleSave" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="Lưu Ca Làm" />
    </HBox>
</VBox>