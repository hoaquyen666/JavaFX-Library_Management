<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>
<VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5px" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.seniormanager.controller.StaffView.AddStaffInfoController" stylesheets="@/style/style.css">

    <Label text="Thêm Nhân viên Mới" textFill="#233771">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <GridPane hgap="10" vgap="15">
        <Label text="Tên Nhân viên:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtFullName" promptText="Nhập tên nhân viên..." GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="text-field"/>

        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="txtEmail" promptText="Nhập Email..." GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="text-field" />

        <Label text="Ngày sinh:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <DatePicker fx:id="dpDob" promptText="Nhập ngày sinh..." GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="date"/>

        <Label text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="txtPhone" promptText="Nhập số điện thoại..." GridPane.columnIndex="1" GridPane.rowIndex="4" styleClass="text-field"/>

        <Label text="Quyền (Role):" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <ComboBox fx:id="cbRole" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <VBox.margin>
            <Insets top="15.0" />
        </VBox.margin>
        <Button onAction="#handleCancel" styleClass="btn-delete" text="Hủy" />
        <Button onAction="#handleSave"  text="Lưu Nhân viên" styleClass="btn-add"/>
    </HBox>

</VBox>
