<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #111827;" stylesheets="@staff.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.administrator.controller.MainViewController">

    <left>
        <VBox fx:id="sidebar" prefWidth="70.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <StackPane prefHeight="80.0">
                    <ImageView fx:id="logoImage" fitHeight="70.0" fitWidth="70.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../../../../../images/Logo-Dai-hoc-CMC-V.png" />
                        </image>
                    </ImageView>
                </StackPane>

                <Button alignment="CENTER_LEFT" onAction="#handleAccount" styleClass="menu-btn" text="Quản lý tài khoản nhân viên">
                    <graphic>
                        <FontIcon iconLiteral="mdi2h-home" iconSize="20" />
                    </graphic>
                </Button>

                <Button alignment="CENTER_LEFT" onAction="#handleStaff" styleClass="menu-btn" text="Quản lý Nhân viên">
                    <graphic>
                        <FontIcon iconLiteral="mdi2b-book" iconSize="20" />
                    </graphic>
                </Button>

                <Button alignment="CENTER_LEFT" onAction="#handleShift" styleClass="menu-btn" text="Quản lý Ca làm">
                    <graphic>
                        <FontIcon iconLiteral="mdi2a-account-group" iconSize="20" />
                    </graphic>
                </Button>


            </children>
        </VBox>
    </left>

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" right="30.0" top="50.0" />
            </padding>
            <children>
                <StackPane fx:id="mainContentArea" styleClass="main-content-card">
                    <!--                    <children>-->
                    <!--                        <Label text="HỆ THỐNG QUẢN LÝ THƯ VIỆN" textFill="#a1a1a1">-->
                    <!--                            <font>-->
                    <!--                                <Font name="System Bold" size="20.0" />-->
                    <!--                            </font>-->
                    <!--                        </Label>-->
                    <!--                    </children>-->
                </StackPane>
            </children>
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
        </StackPane>
    </center>
</BorderPane>
